# ─────────────────────────────────────────────────────────────────
# LLinventory — Supabase Edge Function Secrets (Backend)
#
# These are NOT put in .env.local — they live on the Supabase server.
# To set them: Supabase dashboard → Edge Functions → Manage Secrets
#   OR via CLI: supabase secrets set KEY=value
#
# This file is a TEMPLATE only — fill in real values in the dashboard.
# ─────────────────────────────────────────────────────────────────

# ── Supabase (for edge functions to access the database as admin) ──
SUPABASE_URL=SAME_AS_YOUR_VITE_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVICE_ROLE_KEY_FROM_SUPABASE_DASHBOARD

# ── Xero Integration ──
# Create an app at: https://developer.xero.com/app/manage
# Set redirect URI to: http://localhost:5175/xero-callback (local dev)
#                  or: https://YOUR_PRODUCTION_URL/xero-callback (production)
XERO_CLIENT_ID=PASTE_XERO_APP_CLIENT_ID_HERE
XERO_CLIENT_SECRET=PASTE_XERO_APP_CLIENT_SECRET_HERE
XERO_REDIRECT_URI=http://localhost:5175/xero-callback

# ── Shopify Integration ──
# Create a custom app at: Shopify admin → Apps → Develop apps
# Needs read access to: orders, products, customers, inventory
SHOPIFY_STORE_DOMAIN=leanliving.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=PASTE_SHOPIFY_ADMIN_API_ACCESS_TOKEN_HERE
SHOPIFY_API_VERSION=2024-01

# ── Cin7 Integration (if used) ──
SHOPIFY_CIN7_API_KEY=PASTE_CIN7_API_KEY_HERE
CIN7_API_USERNAME=PASTE_CIN7_USERNAME_HERE
